# ── OS / editor cruft ─────────────────────────────────────────────
.DS_Store
Thumbs.db
*~

# ── Python ────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
.venv/
venv/
.ipynb_checkpoints/

# ── Excel lock & temp files ───────────────────────────────────────
.~lock.*#
~$*.xlsx
*.tmp

# ── Transient pipeline output (regenerated each run) ──────────────
_tools/pending_edges_*.csv

# ── Raw third-party research (licensed/copyrighted — DO NOT publish) ──
# The extracted knowledge (spreadsheet + wiki + graph) is committed;
# the underlying analyst PDFs / expert-call transcripts / holdings files are not.
# Folder structure and the drop-zone README are kept so the pipeline still works.
sources/inbox/*
!sources/inbox/README.md

# ── X/Twitter scan reports (unverified, paraphrased third-party chatter) ──
X-Reports/

# ── Obsidian: keep shared vault config, ignore machine-specific state ──
.obsidian/workspace.json
.obsidian/workspace-mobile.json
.obsidian/workspace.json.bak
.obsidian/cache

# Live-price cache (regenerated at runtime via the proxy; don't commit raw history)
_tools/prices_history.json

# Backtest price history (regenerate locally via fetch_history.py; not committed)
_tools/prices_history.csv

# ── Trading experiment: PRIVATE — contains account number, email, balances, positions ──
TRADING-POLICY.md
TRADING-EXPERIMENT-PLAN.md
HANDOVER.md
briefs/
trading_log.csv
_tools/trading_run.ps1
_tools/send_digest.ps1

# Machine-local Claude Code settings
.claude/settings.local.json
